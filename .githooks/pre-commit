#!/usr/bin/env bash
# i18n parity gate — block commits whose staged content/*.md files don't have
# their language-counterpart sibling. Works in BOTH directions:
#   foo.md      (Italian) requires foo.en.md
#   foo.en.md   (English) requires foo.md
# Excluded: _index.md (Hugo allows IT-only section indexes), anything outside
# content/.
#
# Bypass for emergencies: git commit --no-verify (CI parity check is the
# non-bypassable gate — see .github/workflows/i18n-parity.yml).

set -euo pipefail

# Files staged for commit (Added/Modified/Renamed), filtered to content/*.md
mapfile -t staged < <(
  git diff --cached --name-only --diff-filter=AMR \
    | grep -E '^content/.*\.md$' || true
)

[[ ${#staged[@]} -eq 0 ]] && exit 0

# Helper: returns 0 if path exists in tree OR is also staged in this commit.
have() {
  [[ -f "$1" ]] && return 0
  printf '%s\n' "${staged[@]}" | grep -qx "$1"
}

missing=()
for f in "${staged[@]}"; do
  base=$(basename "$f")
  dir=$(dirname "$f")

  # Section indexes are allowed IT-only (Hugo handles this gracefully).
  [[ "$base" == _index.md ]] && continue

  if [[ "$base" == *.en.md ]]; then
    # EN side → require IT sibling (drop the .en suffix)
    stem="${base%.en.md}"
    sibling="${dir}/${stem}.md"
    have "$sibling" || missing+=("$f → expected IT sibling $sibling")
  else
    # IT side → require EN sibling (insert .en before .md)
    stem="${base%.md}"
    sibling="${dir}/${stem}.en.md"
    have "$sibling" || missing+=("$f → expected EN sibling $sibling")
  fi
done

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "✗ i18n parity check failed: missing language counterpart(s)" >&2
  printf '  - %s\n' "${missing[@]}" >&2
  echo >&2
  echo "Add the missing sibling file(s) before committing." >&2
  echo "Bypass (last resort): git commit --no-verify" >&2
  exit 1
fi

exit 0
